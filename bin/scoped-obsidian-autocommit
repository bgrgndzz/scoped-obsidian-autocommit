#!/usr/bin/env bash
set -euo pipefail

PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

SOURCE_PATH="${SOURCE_PATH:-}"
MIRROR_REPO="${MIRROR_REPO:-}"
REMOTE_URL="${REMOTE_URL:-}"
BRANCH="${BRANCH:-main}"
MESSAGE_PREFIX="${MESSAGE_PREFIX:-Auto-commit}"
PUSH="${PUSH:-1}"
DRY_RUN="${DRY_RUN:-0}"
ALLOW_OBSIDIAN_ROOT="${ALLOW_OBSIDIAN_ROOT:-0}"
SYNC_BACKEND="${SYNC_BACKEND:-rsync}"
EXCLUDE_PATTERNS=(
  ".git/"
  ".obsidian/"
  ".trash/"
  ".DS_Store"
  "Thumbs.db"
)

usage() {
  cat <<'USAGE'
scoped-obsidian-autocommit

Mirror one Obsidian subfolder into a separate Git repo, auto-commit changes,
and optionally push to a configured remote.

Usage:
  scoped-obsidian-autocommit --source PATH --repo PATH --remote URL [options]
  scoped-obsidian-autocommit --config FILE [options]

Options:
  --config FILE                 Load shell-style config before parsing later args
  --source PATH                 Obsidian subtree to publish
  --repo PATH                   Local mirror Git repo
  --remote URL                  GitHub remote for the mirror repo
  --branch NAME                 Branch to commit to (default: main)
  --message-prefix TEXT         Commit message prefix (default: Auto-commit)
  --exclude PATTERN             Additional rsync exclude pattern; repeatable
  --dry-run                     Show what would sync without changing files
  --no-push                     Commit locally but do not push
  --allow-obsidian-root         Allow source paths containing a .obsidian folder
  --sync-backend NAME           rsync, git-archive, or auto (default: rsync)
  -h, --help                    Show this help

Config files are trusted shell snippets. Supported variables:
  SOURCE_PATH, MIRROR_REPO, REMOTE_URL, BRANCH, MESSAGE_PREFIX, PUSH,
  DRY_RUN, ALLOW_OBSIDIAN_ROOT, SYNC_BACKEND, EXCLUDE_PATTERNS
USAGE
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

push_if_enabled() {
  if [[ "$PUSH" != "1" ]]; then
    return 0
  fi

  [[ -n "$REMOTE_URL" ]] || die "push enabled but no remote configured"

  if ! git -C "$MIRROR_REPO" rev-parse --verify HEAD >/dev/null 2>&1; then
    printf 'no commits to push\n'
    return 0
  fi

  git -C "$MIRROR_REPO" push -u origin "$BRANCH"
}

realpath_portable() {
  local target="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$target"
  else
    if [[ -d "$target" ]]; then
      (cd "$target" && pwd -P)
    else
      local dir
      local base
      dir="$(dirname "$target")"
      base="$(basename "$target")"
      printf '%s/%s\n' "$(cd "$dir" && pwd -P)" "$base"
    fi
  fi
}

load_config() {
  local file="$1"
  [[ -f "$file" ]] || die "config file not found: $file"
  # shellcheck source=/dev/null
  source "$file"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)
      [[ $# -ge 2 ]] || die "--config needs a file"
      load_config "$2"
      shift 2
      ;;
    --source)
      [[ $# -ge 2 ]] || die "--source needs a path"
      SOURCE_PATH="$2"
      shift 2
      ;;
    --repo)
      [[ $# -ge 2 ]] || die "--repo needs a path"
      MIRROR_REPO="$2"
      shift 2
      ;;
    --remote)
      [[ $# -ge 2 ]] || die "--remote needs a URL"
      REMOTE_URL="$2"
      shift 2
      ;;
    --branch)
      [[ $# -ge 2 ]] || die "--branch needs a name"
      BRANCH="$2"
      shift 2
      ;;
    --message-prefix)
      [[ $# -ge 2 ]] || die "--message-prefix needs text"
      MESSAGE_PREFIX="$2"
      shift 2
      ;;
    --exclude)
      [[ $# -ge 2 ]] || die "--exclude needs a pattern"
      EXCLUDE_PATTERNS+=("$2")
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --no-push)
      PUSH=0
      shift
      ;;
    --allow-obsidian-root)
      ALLOW_OBSIDIAN_ROOT=1
      shift
      ;;
    --sync-backend)
      [[ $# -ge 2 ]] || die "--sync-backend needs a name"
      SYNC_BACKEND="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

[[ -n "$SOURCE_PATH" ]] || die "missing --source or SOURCE_PATH"
[[ -n "$MIRROR_REPO" ]] || die "missing --repo or MIRROR_REPO"
case "$SYNC_BACKEND" in
  rsync|git-archive|auto) ;;
  *) die "unsupported sync backend: $SYNC_BACKEND" ;;
esac

[[ -d "$SOURCE_PATH" ]] || die "source path is not a directory: $SOURCE_PATH"
mkdir -p "$MIRROR_REPO"

SOURCE_PATH="$(realpath_portable "$SOURCE_PATH")"
MIRROR_REPO="$(realpath_portable "$MIRROR_REPO")"

[[ "$SOURCE_PATH" != "/" ]] || die "refusing to publish filesystem root"
[[ "$SOURCE_PATH" != "$HOME" ]] || die "refusing to publish home directory"
[[ "$SOURCE_PATH" != "$MIRROR_REPO" ]] || die "source and mirror repo must differ"

case "$MIRROR_REPO/" in
  "$SOURCE_PATH"/*) die "mirror repo must not be inside source path" ;;
esac
case "$SOURCE_PATH/" in
  "$MIRROR_REPO"/*) die "source path must not be inside mirror repo" ;;
esac

if [[ -d "$SOURCE_PATH/.obsidian" && "$ALLOW_OBSIDIAN_ROOT" != "1" ]]; then
  die "source contains .obsidian; pick a subfolder or pass --allow-obsidian-root"
fi

LOCK_ID="$(printf '%s\n%s\n' "$SOURCE_PATH" "$MIRROR_REPO" | cksum | awk '{print $1}')"
LOCK_DIR="${TMPDIR:-/tmp}/scoped-obsidian-autocommit.${LOCK_ID}.lock"
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  die "another scoped autocommit is already running for this source/repo"
fi
trap 'rm -rf "$LOCK_DIR"' EXIT

rsync_args=(-a --delete)
for pattern in "${EXCLUDE_PATTERNS[@]}"; do
  rsync_args+=(--exclude "$pattern")
done

sync_with_rsync() {
  rsync "${rsync_args[@]}" "$SOURCE_PATH/" "$MIRROR_REPO/"
}

sync_with_git_archive() {
  local git_root
  local source_prefix
  local archive_ref
  local pathspec
  local pattern

  # LaunchAgents and manual runs can start from a directory that later gets
  # replaced during mirror cleanup. Keep destructive cleanup rooted somewhere
  # stable so macOS find never operates from a disappearing cwd.
  cd /

  git_root="$(git -C "$SOURCE_PATH" rev-parse --show-toplevel)" || return 1
  source_prefix="$(git -C "$SOURCE_PATH" rev-parse --show-prefix)" || return 1
  source_prefix="${source_prefix%/}"
  pathspec="${source_prefix:-.}"

  if [[ -n "$(git -C "$git_root" status --porcelain -- "$pathspec")" ]]; then
    printf 'git-archive backend cannot mirror uncommitted source changes: %s\n' "$SOURCE_PATH" >&2
    printf 'commit the source repo first, or use rsync from a process with folder access\n' >&2
    return 1
  fi

  find "$MIRROR_REPO" -mindepth 1 -maxdepth 1 ! -name .git -exec rm -rf {} +

  if [[ -n "$source_prefix" ]]; then
    archive_ref="HEAD:${source_prefix}"
  else
    archive_ref="HEAD"
  fi

  git -C "$git_root" archive "$archive_ref" | tar -x -C "$MIRROR_REPO"

  for pattern in "${EXCLUDE_PATTERNS[@]}"; do
    case "$pattern" in
      */)
        find "$MIRROR_REPO" -mindepth 2 -name "${pattern%/}" -type d -prune -exec rm -rf {} +
        ;;
      .DS_Store|Thumbs.db)
        find "$MIRROR_REPO" -name "$pattern" -type f -delete
        ;;
    esac
  done
}

sync_source() {
  case "$SYNC_BACKEND" in
    rsync)
      sync_with_rsync
      ;;
    git-archive)
      sync_with_git_archive
      ;;
    auto)
      sync_with_rsync || {
        local status="$?"
        printf 'rsync failed with status %s; falling back to git archive\n' "$status" >&2
        sync_with_git_archive
      }
      ;;
  esac
}

printf 'source: %s\n' "$SOURCE_PATH"
printf 'mirror: %s\n' "$MIRROR_REPO"
printf 'branch: %s\n' "$BRANCH"

if [[ "$DRY_RUN" == "1" ]]; then
  printf 'mode: dry-run\n'
  if [[ "$SYNC_BACKEND" == "git-archive" ]]; then
    git_root="$(git -C "$SOURCE_PATH" rev-parse --show-toplevel)"
    source_prefix="$(git -C "$SOURCE_PATH" rev-parse --show-prefix)"
    source_prefix="${source_prefix%/}"
    if [[ -n "$source_prefix" ]]; then
      git -C "$git_root" archive "HEAD:${source_prefix}" | tar -tf -
    else
      git -C "$git_root" archive HEAD | tar -tf -
    fi
  else
    rsync -ani --delete "${rsync_args[@]:2}" "$SOURCE_PATH/" "$MIRROR_REPO/"
  fi
  exit 0
fi

if [[ ! -d "$MIRROR_REPO/.git" ]]; then
  git -C "$MIRROR_REPO" init -b "$BRANCH"
fi

current_branch="$(git -C "$MIRROR_REPO" branch --show-current || true)"
if [[ "$current_branch" != "$BRANCH" ]]; then
  git -C "$MIRROR_REPO" checkout -B "$BRANCH"
fi

if [[ -n "$REMOTE_URL" ]]; then
  if git -C "$MIRROR_REPO" remote get-url origin >/dev/null 2>&1; then
    git -C "$MIRROR_REPO" remote set-url origin "$REMOTE_URL"
  else
    git -C "$MIRROR_REPO" remote add origin "$REMOTE_URL"
  fi
fi

sync_source

if [[ -z "$(git -C "$MIRROR_REPO" status --porcelain)" ]]; then
  printf 'no changes\n'
  push_if_enabled
  exit 0
fi

git -C "$MIRROR_REPO" add -A
git -C "$MIRROR_REPO" commit -m "$MESSAGE_PREFIX: $(date '+%Y-%m-%d %H:%M:%S')"
push_if_enabled
