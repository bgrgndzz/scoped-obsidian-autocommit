# Copy to ~/.config/scoped-obsidian-autocommit/ai-research.env and edit.
# This file is intentionally an example. Do not commit private local configs.

SOURCE_PATH="/Users/you/Documents/Obsidian Vault/AI Research"
MIRROR_REPO="/Users/you/Developer/ai-research-zettelkasten"
REMOTE_URL="git@github.com:your-org/ai-research-zettelkasten.git"
BRANCH="main"
MESSAGE_PREFIX="Auto-commit AI research zettelkasten"
PUSH=1
DRY_RUN=0
SYNC_BACKEND="auto"

EXCLUDE_PATTERNS=(
  ".git/"
  ".obsidian/"
  ".trash/"
  ".DS_Store"
  "Thumbs.db"
)
